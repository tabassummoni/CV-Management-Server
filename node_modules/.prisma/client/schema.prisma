generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int             @id @default(autoincrement())
  name          String?
  email         String          @unique
  password      String?
  role          String          @default("Candidate")
  createdAt     DateTime        @default(now())
  profileValues UserAttribute[]
  cvs           CV[]
}

model Attribute {
  id          Int                 @id @default(autoincrement())
  category    String
  name        String              @unique
  description String?
  dataType    String
  userValues  UserAttribute[]
  positions   PositionAttribute[]
}

model UserAttribute {
  id          Int       @id @default(autoincrement())
  userId      Int
  attributeId Int
  value       String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([userId, attributeId])
}

model Position {
  id               Int                 @id @default(autoincrement())
  title            String
  shortDescription String?
  maxProjects      Int                 @default(3)
  projectTags      String[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  attributes       PositionAttribute[]
  cvs              CV[]
}

model PositionAttribute {
  id          Int       @id @default(autoincrement())
  positionId  Int
  attributeId Int
  position    Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([positionId, attributeId])
}

model CV {
  id          Int      @id @default(autoincrement())
  title       String
  isPublished Boolean  @default(false)
  version     Int      @default(1)
  userId      Int
  positionId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}
