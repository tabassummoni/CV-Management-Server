generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String?
  email        String        @unique
  password     String?
  role         String        @default("CANDIDATE") 
  createdAt    DateTime      @default(now())
  cvs          CV[]          @relation("CvsToUser")
  comments     Comment[]
  applications Application[]
}

model CV {
  id           Int           @id @default(autoincrement())
  title        String   
  fullName     String        @default("") 
  email        String        @default("") 
  phone        String?
  summary      String?       @db.Text
  skills       String        @default("") 
  ieltsScore   String?  
  experience   String?       @db.Text
  education    String?       @db.Text
  projects     String?       @db.Text
  version      Int           @default(1)
  isPublished  Boolean       @default(false)
  userId       Int      
  user         User          @relation("CvsToUser", fields: [userId], references: [id], onDelete: Cascade)
  positionId   Int
  position     Position      @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  attributes Attribute[]
}

model Attribute {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  dataType    String       
  categoryId  Int
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  positions   Position[] @relation("PositionAttributes")
}

model Position {
  id           Int           @id @default(autoincrement())
  title        String
  companyName  String?
  description  String        @db.Text
  maxProjects  Int           @default(3)
  projectTags  String[]    
  deadline     DateTime?   
  version      Int           @default(1) 
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  attributes   Attribute[]   @relation("PositionAttributes")
  cvs          CV[]        
  comments     Comment[]
  applications Application[]
}

model Application {
  id         Int      @id @default(autoincrement())
  userId     Int
  cvId       Int
  positionId Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv       CV       @relation(fields: [cvId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  createdAt  DateTime @default(now())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId Int
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}